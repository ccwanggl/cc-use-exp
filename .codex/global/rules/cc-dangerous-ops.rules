# Prompt before mutating repository, package, service, container, cluster, or database state.

prefix_rule(
    pattern = ["git", ["add", "commit", "push", "tag"]],
    decision = "prompt",
    justification = "Git write operations should stay user-confirmed.",
    match = [
        "git add .",
        "git commit -m fix",
        "git push origin main",
        "git tag v1.0.0",
    ],
)

prefix_rule(
    pattern = [["npm", "pnpm", "yarn"], ["install", "add", "remove", "update"]],
    decision = "prompt",
    justification = "Dependency changes can alter the workspace and lockfiles.",
    match = [
        "npm install",
        "pnpm add zod",
        "yarn remove lodash",
    ],
)

prefix_rule(
    pattern = ["systemctl", ["start", "stop", "restart", "reload", "enable", "disable", "mask", "unmask", "daemon-reload", "kill"]],
    decision = "prompt",
    justification = "Mutating service state can affect the local machine or shared environment.",
    match = [
        "systemctl restart nginx",
        "systemctl stop docker",
        "systemctl daemon-reload",
    ],
    not_match = [
        "systemctl status nginx",
    ],
)

prefix_rule(
    pattern = ["service"],
    decision = "prompt",
    justification = "Service management commands should stay user-confirmed.",
    match = [
        "service nginx restart",
        "service docker stop",
    ],
)

prefix_rule(
    pattern = ["launchctl", ["load", "unload", "bootstrap", "bootout", "enable", "disable", "kickstart", "kill", "submit", "remove"]],
    decision = "prompt",
    justification = "Mutating launchctl state can affect running services outside the workspace.",
    match = [
        "launchctl kickstart -k system/com.apple.cfprefsd.xpc.daemon",
        "launchctl unload ~/Library/LaunchAgents/com.example.app.plist",
    ],
    not_match = [
        "launchctl list",
    ],
)

prefix_rule(
    pattern = ["docker", ["run", "exec", "start", "stop", "restart", "kill", "rm", "rmi", "build", "pull", "push", "cp", "tag"]],
    decision = "prompt",
    justification = "Mutating container or image state can have a broad blast radius.",
    match = [
        "docker run -d nginx",
        "docker exec api sh",
        "docker restart api",
        "docker rm api",
        "docker build -t api .",
    ],
    not_match = [
        "docker ps",
        "docker logs api",
    ],
)

prefix_rule(
    pattern = ["docker", "compose", ["up", "down", "restart", "stop", "start", "kill", "rm", "build", "pull", "push", "exec", "run"]],
    decision = "prompt",
    justification = "Compose lifecycle operations can reconfigure or replace running services.",
    match = [
        "docker compose up -d",
        "docker compose down",
        "docker compose restart api",
        "docker compose exec api sh",
    ],
    not_match = [
        "docker compose ps",
        "docker compose logs api",
    ],
)

prefix_rule(
    pattern = ["kubectl", ["apply", "create", "replace", "edit", "delete", "patch", "annotate", "label", "scale", "autoscale", "exec", "cp", "drain", "cordon", "uncordon", "taint"]],
    decision = "prompt",
    justification = "Mutating cluster state or entering workloads should stay user-confirmed.",
    match = [
        "kubectl apply -f deploy.yaml",
        "kubectl delete pod foo",
        "kubectl exec -it api-123 -- sh",
        "kubectl scale deploy/api --replicas=3",
    ],
    not_match = [
        "kubectl get pods -A",
        "kubectl logs deploy/api",
    ],
)

prefix_rule(
    pattern = ["kubectl", "rollout", ["restart", "undo", "pause", "resume"]],
    decision = "prompt",
    justification = "Rollout-changing operations should stay explicitly approved.",
    match = [
        "kubectl rollout restart deploy/api",
        "kubectl rollout undo deploy/api",
    ],
)

prefix_rule(
    pattern = ["kubectl", "config", ["set-context", "use-context", "delete-context", "rename-context", "set-cluster", "set-credentials", "unset"]],
    decision = "prompt",
    justification = "Changing kubeconfig can redirect later commands to a different cluster.",
    match = [
        "kubectl config use-context prod",
        "kubectl config delete-context old-prod",
    ],
    not_match = [
        "kubectl config current-context",
    ],
)

prefix_rule(
    pattern = [["mysql", "psql", "sqlite3"]],
    decision = "prompt",
    justification = "Database clients can read or mutate real data; keep access user-confirmed.",
    match = [
        "mysql -u root -p",
        "psql -h localhost -d mydb",
        "sqlite3 app.db",
    ],
)

prefix_rule(
    pattern = ["mkdir", "-p", [".codex/tasks", ".codex/tasks/archived", ".codex/templates"]],
    decision = "prompt",
    justification = "Initializing project-local .codex task directories writes into the current repository and should stay user-confirmed when workspace permission is required.",
    match = [
        "mkdir -p .codex/tasks",
        "mkdir -p .codex/tasks/archived",
        "mkdir -p .codex/templates",
    ],
)

prefix_rule(
    pattern = ["rm"],
    decision = "forbidden",
    justification = "Use safer, reviewed file edits instead of direct deletion commands.",
    match = ["rm -rf tmp"],
)

prefix_rule(
    pattern = ["sudo", "rm"],
    decision = "forbidden",
    justification = "Do not run privileged delete commands automatically.",
    match = ["sudo rm -rf /tmp/foo"],
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Hard reset is destructive. Use a safer alternative after explicit review.",
    match = ["git reset --hard HEAD~1"],
)

prefix_rule(
    pattern = ["git", "clean", "-fd"],
    decision = "forbidden",
    justification = "Force-clean removes untracked files destructively.",
    match = ["git clean -fd"],
)

prefix_rule(
    pattern = [["mkfs", "dd", "shutdown", "reboot"]],
    decision = "forbidden",
    justification = "Highly destructive system-level commands must not run automatically.",
    match = ["reboot", "shutdown -r now"],
)
